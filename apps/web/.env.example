VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push. Generate a VAPID keypair with `npx web-push generate-vapid-keys`;
# the public key goes here, the private key goes to the Cloudflare Worker
# (Phase 11). VITE_PUSH_WORKER_URL is the deployed worker's base URL; leave it
# blank to have the app store push subscriptions straight to Supabase instead.
VITE_VAPID_PUBLIC_KEY=
VITE_PUSH_WORKER_URL=
